                                      5 
                                      6         .module mulint
                                      7         .optsdcc -mz80 sdcccall(1)
                                      8 
                                      9         .globl  __mulint
                                     10         .area   _CODE
                                     11 
    00000000                         12 __mulint::
                                     13         ;; Move HL to BC for the multiplication algorithm.
    00000000 44               [ 4]   14         ld      b, h
    00000001 4D               [ 4]   15         ld      c, l
    00000002                         16 __mul16:
    00000002 AF               [ 4]   17         xor     a, a
    00000003 6F               [ 4]   18         ld      l, a
    00000004 B0               [ 4]   19         or      a, b
    00000005 06 10            [ 7]   20         ld      b, #16
    00000007 20 04            [12]   21         jr      nz, 2$
    00000009 06 08            [ 7]   22         ld      b, #8
    0000000B 79               [ 4]   23         ld      a, c
    0000000C                         24 1$:
    0000000C 29               [11]   25         add     hl, hl
    0000000D                         26 2$:
    0000000D CB 11            [ 8]   27         rl      c
    0000000F 17               [ 4]   28         rla
    00000010 30 01            [12]   29         jr      nc, 3$
    00000012 19               [11]   30         add     hl, de
    00000013                         31 3$:
    00000013 10 F7            [13]   32         djnz    1$
    00000015 C9               [10]   33         ret
