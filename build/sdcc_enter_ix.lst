                                      6         .module enter_ix
                                      7         .optsdcc -mz80 sdcccall(1)
                                      8 
                                      9         .globl  ___sdcc_enter_ix
                                     10         .globl  __sdcc_enter_ix
                                     11         .area   _CODE
                                     12 
    00000000                         13 ___sdcc_enter_ix:
    00000000                         14 __sdcc_enter_ix:
    00000000 E1               [10]   15         pop     hl
    00000001 DD E5            [15]   16         push    ix
    00000003 DD 21 00 00      [14]   17         ld      ix, #0
    00000007 DD 39            [15]   18         add     ix, sp
    00000009 E9               [ 4]   19         jp      (hl)
