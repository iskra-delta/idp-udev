                                     40         ;; return (status) codes
                         00000000    41         .equ    R_SUCCESS,      0       ; all good that ends good
                         00000001    42         .equ    R_UNEXPECT,     1       ; unexpected symbol
                         00000002    43         .equ    R_INVALID_FN,   2       ; function not defined
                         00000003    44         .equ    R_INVALID_AREA, 3       ; area not in 0-15 range
                         00000004    45         .equ    R_SSTACK_OF,    4       ; symbol stack overflow
                         00000005    46         .equ    R_FNAME_OF,     5       ; filename overflow
                         00000006    47         .equ    R_EXT_OF,       6       ; extension overflow
