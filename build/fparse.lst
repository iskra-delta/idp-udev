                                    377         ;; ----- automata definition ------------------------------------------
                                    378         ;; each transition is 2 bytes
                                    379         ;; byte 0:
                                    380         ;;  TTTTSSSS    T=test, S=start
                                    381         ;; byte 1:
                                    382         ;;  FFFFEEEE    F=function, E=end
                                    383         ;; example:
                                    384         ;;  00010000, 00000001 (start=0, test=1, function=0, end=1)
