    0000004B FD 7E 02         [19]  111         ld      a,2(iy)
    0000004E E6 0F            [ 7]  112         and     #0x0f
    00000050 FE 07            [ 7]  113         cp      #S_END
    00000052 28 30            [12]  114         jr      z,fpa_done
                                    115         ;; loop
    00000054 E1               [10]  116         pop     hl                      ; restore hl
    00000055 23               [ 6]  117         inc     hl                      ; next symbol
    00000056 18 E7            [12]  118         jr      fpa_nextsym             ; and loop
                                    119         ;; find transition
    00000058                        120 fpa_find_transition:
    00000058 21 A7 01         [10]  121         ld      hl,#fpa_automata        ; address of mealy automata
                                    122         ;; b=total transitions
    0000005B 06 0F            [ 7]  123         ld      b,#((efpa_automata-fpa_automata)/2)
    0000005D 4F               [ 4]  124         ld      c,a                     ; store a
    0000005E                        125 fpaft_loop:
    0000005E 7E               [ 7]  126         ld      a,(hl)                  ; get first byte
    0000005F E6 0F            [ 7]  127         and     #0b00001111             ; get state
    00000061 FD BE 02         [19]  128         cp      2(iy)                   ; is it current state?
    00000064 CC 9D 00         [17]  129         call    z,fpaft_test            ; call test
    00000067 20 0E            [12]  130         jr      nz,fpaft_next           ; test failed, next trans.
    00000069 23               [ 6]  131         inc     hl                      ; get next byte
    0000006A 7E               [ 7]  132         ld      a,(hl)                  ; get second byte to a
    0000006B E6 0F            [ 7]  133         and     #0b00001111             ; grab next state
    0000006D FD 77 02         [19]  134         ld      2(iy),a                 ; store to current state
    00000070 7E               [ 7]  135         ld      a,(hl)                  ; get second byte to a
    00000071 E6 F0            [ 7]  136         and     #0b11110000             ; extract function
    00000073 6F               [ 4]  137         ld      l,a                     ; get function to l
                                    138         ;; and return success
    00000074 AF               [ 4]  139         xor     a
    00000075 79               [ 4]  140         ld      a,c
    00000076 C9               [10]  141         ret
    00000077                        142 fpaft_next:
    00000077 23               [ 6]  143         inc     hl                      ; next state
    00000078 23               [ 6]  144         inc     hl
    00000079 10 E3            [13]  145         djnz    fpaft_loop              ; and loop it
                                    146         ;; if we are here, we did not find
                                    147         ;; the transition. clear zero flag!
    0000007B                        148 fpaft_unexpect_sym:
    0000007B FD 36 03 01      [19]  149         ld      3(iy), #R_UNEXPECT
    0000007F                        150 fpaft_set_z:
    0000007F AF               [ 4]  151         xor     a
    00000080 FE FF            [ 7]  152         cp      #0xff                   ; rest z flag
    00000082 79               [ 4]  153         ld      a,c                     ; resotre a
    00000083 C9               [10]  154         ret
                                    155         ;; we're done parsing
    00000084                        156 fpa_done:
    00000084 E1               [10]  157         pop     hl                      ; clear stack
                                    158         ;; set result
    00000085 26 00            [ 7]  159         ld      h,#0                    
    00000087 FD 6E 03         [19]  160         ld      l,3(iy)
                                    161         ;; set area
    0000008A FD 7E 04         [19]  162         ld      a,4(iy)                 ; get area
    0000008D D9               [ 4]  163         exx
    0000008E 02               [ 7]  164         ld      (bc),a                  ; set area
                                    165         ;; convert drive to uppercase
