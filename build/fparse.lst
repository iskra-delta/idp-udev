                                     56         ;; Need: HL=path, DE'=fcb, BC'=area
                                     57         ;; Strategy: Push fcb, read area, push area, exx, pop to BC' and DE'
    00000000 D5               [11]   58         push    de                      ; save fcb
                                     59         ;; Stack now: [fcb][ret_addr][area]
                                     60         ;; Read area from SP+4 and SP+5 into BC temporarily
    00000001 DD 21 04 00      [14]   61         ld      ix,#4
    00000005 DD 39            [15]   62         add     ix,sp
    00000007 DD 4E 00         [19]   63         ld      c,(ix)                  ; area_lo from stack
    0000000A DD 46 01         [19]   64         ld      b,1(ix)                 ; area_hi from stack
    0000000D C5               [11]   65         push    bc                      ; push area
                                     66         ;; Stack now: [area][fcb][ret_addr][area_on_stack]
                                     67         ;; Switch to alternate and set up BC'=area, DE'=fcb
    0000000E D9               [ 4]   68         exx
    0000000F C1               [10]   69         pop     bc                      ; BC' = area pointer
    00000010 D1               [10]   70         pop     de                      ; DE' = fcb pointer
                                     71         ;; Now initialize FCB (DE' points to it)
    00000011 D5               [11]   72         push    de                      ; save fcb
    00000012 AF               [ 4]   73         xor     a                       ; a=0
    00000013 12               [ 7]   74         ld      (de),a                  ; default drive
    00000014 13               [ 6]   75         inc     de                      ; skip over default
    00000015 06 0B            [ 7]   76         ld      b,#11                   ; 8+3 filename
    00000017 3E 20            [ 7]   77         ld      a,#' '                  ; pad with spaces
    00000019                         78 fpa_init_fcb:
    00000019 12               [ 7]   79         ld      (de),a
    0000001A 13               [ 6]   80         inc     de
    0000001B 10 FC            [13]   81         djnz    fpa_init_fcb
    0000001D D1               [10]   82         pop     de                      ; restore DE' = fcb
                                     83         ;; Switch back to normal registers
    0000001E D9               [ 4]   84         exx
                                     85         ;; HL still contains path (never changed it)
                                     86         ;; restore stack and make iy point to it
    0000001F FD 21 F8 FF      [14]   87         ld      iy,#-8
    00000023 FD 39            [15]   88         add     iy,sp
    00000025 FD F9            [10]   89         ld      sp,iy
                                     90         ;; we will use space from 2(iy) to 7(iy) as
                                     91         ;; local variables ... overwriting arguments
    00000027 FD 36 02 00      [19]   92         ld      2(iy),#S_START          ; initial state to 2(iy)!
    0000002B FD 36 03 01      [19]   93         ld      3(iy),#R_UNEXPECT       ; status is unexpected
    0000002F FD 36 04 FF      [19]   94         ld      4(iy),#DEFAULT_AREA     ; default area
    00000033 FD 36 05 00      [19]   95         ld      5(iy),#NO_SYM           ; stacked symbol
    00000037 FD 36 06 00      [19]   96         ld      6(iy),#0                ; fname len
    0000003B FD 36 07 00      [19]   97         ld      7(iy),#0                ; ext len
                                     98         ;; main loop
    0000003F                         99 fpa_nextsym:
                                    100         ;; get next symbol
    0000003F 7E               [ 7]  101         ld      a,(hl)
    00000040 E5               [11]  102         push    hl                      ; store hl!
                                    103         ;; find transition
    00000041 CD 58 00         [17]  104         call    fpa_find_transition
                                    105         ;; if not found then unexpected error
    00000044 20 3E            [12]  106         jr      nz,fpa_done
                                    107         ;; else transition function id is in register l
    00000046 CD D9 00         [17]  108         call    fpa_execfn
    00000049 20 39            [12]  109         jr      nz,fpa_done             ; if not zero then status!
                                    110         ;; is it final state?
