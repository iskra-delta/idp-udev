                         00000000    14         .equ    S_START,        0b00000000
                         00000001    15         .equ    S_AREA,         0b00000001
                         00000002    16         .equ    S_DRIVE,        0b00000010
                         00000003    17         .equ    S_FNAME0,       0b00000011
                         00000004    18         .equ    S_FNAME,        0b00000100
                         00000005    19         .equ    S_EXT0,         0b00000101
                         00000006    20         .equ    S_EXT,          0b00000110
                         00000007    21         .equ    S_END,          0b00000111
