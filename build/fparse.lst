                         00000000    24         .equ    T_ELSE,         0b00000000
                         00000010    25         .equ    T_DIGIT,        0b00010000
                         00000020    26         .equ    T_COLON,        0b00100000
                         00000030    27         .equ    T_DOT,          0b00110000
                         00000040    28         .equ    T_ALPHA,        0b01000000
                         00000050    29         .equ    T_ASCII7,       0b01010000
                         00000060    30         .equ    T_ZERO,         0b01100000
