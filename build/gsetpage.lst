ASxxxx Assembler V02.00 + NoICE + SDCC mods  (Zilog Z80 / Hitachi HD64180 / ZX-Next / eZ80 / R800)                          Page 4
Hexadecimal [32-Bits]



                                     14 
                                     15         .area    _CODE
                                     16         ;; ----------------------------------------
                                     17         ;; void gsetpage(uint8_t ops, uint8_t page)
                                     18         ;; ----------------------------------------
                                     19         ;; sets the current page, ops are flags and can be
                                     20         ;; combined (i.e.PG_WRITE|PG_DISPLAY), and the
                                     21         ;; page is 0 or 1
                                     22         ;;
                                     23         ;; notes:
                                     24         ;;  this function manipulate bits of destination
                                     25         ;;  through the mask. the mask tells which bits
                                     26         ;;  from the source are copied to the destination
                                     27         ;;
                                     28         ;;  following example destination bits that have
                                     29         ;;  mask set to the source bits.
                                     30         ;;
                                     31         ;;  src       mask      dst      result
                                     32         ;;  10001101  00001111  XXXXXXXX XXXX1101
                                     33         ;;
                                     34         ;;  how does it work?
                                     35         ;;  1. and src with mask     00001101 -> S&M
                                     36         ;;  2. negate the mask       11110000 -> NM
                                     37         ;;  3. and neg.mask with dst XXXX0000 -> NM & D
                                     38         ;;  4. or with src and mask  XXXX1101 -> NM & D | S & M
                                     39         ;;
    00000000                         40 _gsetpage:
                                     41         ;; extend page number to 2nd bit
    00000000 7B               [ 4]   42         ld      a,e                     ; page to a
    00000001 E6 01            [ 7]   43         and     #1                      ; keep only bit 0
    00000003 28 02            [12]   44         jr      z,gsp_select            ; is it 0?
    00000005 F6 02            [ 7]   45         or      #2                      ; set bit 2
    00000007                         46 gsp_select:
    00000007 A5               [ 4]   47         and     l                       ; and with selector (op)
    00000008 4F               [ 4]   48         ld      c,a                     ; store extended page in C
    00000009 7D               [ 4]   49         ld      a,l                     ; get selector (op)
    0000000A 2F               [ 4]   50         cpl                             ; complement it
    0000000B 47               [ 4]   51         ld      b,a                     ; store neg selector into reg B
                                     52         ;; get current state of the page register to a
    0000000C CD 00 00         [17]   53         call    gdp_wait_ready
    0000000F DB 30            [11]   54         in      a,(PIO_GR_CMN)
                                     55         ;; a=xxxxxxxx
    00000011 A0               [ 4]   56         and     b                       ; A=neg selector and current
    00000012 47               [ 4]   57         ld      b,a                     ; store into b
    00000013 B1               [ 4]   58         or      c                       ; final result is in a (OR with extended page)
    00000014 F5               [11]   59         push    af                      ; store result
    00000015 7D               [ 4]   60         ld      a,l                     ; get selector (op)
    00000016 E6 01            [ 7]   61         and     #1                      ; test display page?
    00000018 28 03            [12]   62         jr      z,gsp_write
                                     63         ;; need to wait for vblank
    0000001A CD 00 00         [17]   64         call    gdp_wait_vbl
                                     65         ;; write back to reg!
    0000001D                         66 gsp_write:
    0000001D F1               [10]   67         pop     af                      ; restore a
    0000001E D3 30            [11]   68         out     (PIO_GR_CMN),a          ; set pages!
