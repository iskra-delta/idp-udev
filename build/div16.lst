                                      8         .module div16
                                      9         .optsdcc -mz80 sdcccall(1)
                                     10 
                                     11         .globl  __div16
                                     12         .globl  __divu16
                                     13         .area   _CODE
                                     14 
    00000000                         15 __div16::
    00000000 7C               [ 4]   16         ld      a, h
    00000001 AA               [ 4]   17         xor     a, d
    00000002 17               [ 4]   18         rla
    00000003 7C               [ 4]   19         ld      a, h
    00000004 F5               [11]   20         push    af
                                     21 
    00000005 17               [ 4]   22         rla
    00000006 30 06            [12]   23         jr      nc, .chkde
    00000008 97               [ 4]   24         sub     a, a
    00000009 95               [ 4]   25         sub     a, l
    0000000A 6F               [ 4]   26         ld      l, a
    0000000B 9F               [ 4]   27         sbc     a, a
    0000000C 94               [ 4]   28         sub     a, h
    0000000D 67               [ 4]   29         ld      h, a
                                     30 
    0000000E                         31 .chkde:
    0000000E CB 7A            [ 8]   32         bit     7, d
    00000010 28 06            [12]   33         jr      z, .dodiv
    00000012 97               [ 4]   34         sub     a, a
    00000013 93               [ 4]   35         sub     a, e
    00000014 5F               [ 4]   36         ld      e, a
    00000015 9F               [ 4]   37         sbc     a, a
    00000016 92               [ 4]   38         sub     a, d
    00000017 57               [ 4]   39         ld      d, a
                                     40 
    00000018                         41 .dodiv:
    00000018 CD 00 00         [17]   42         call    __divu16
                                     43 
    0000001B                         44 .fix_quotient:
    0000001B F1               [10]   45         pop     af
    0000001C D0               [11]   46         ret     nc
    0000001D 47               [ 4]   47         ld      b, a
    0000001E 97               [ 4]   48         sub     a, a
    0000001F 95               [ 4]   49         sub     a, l
    00000020 6F               [ 4]   50         ld      l, a
    00000021 9F               [ 4]   51         sbc     a, a
    00000022 94               [ 4]   52         sub     a, h
    00000023 67               [ 4]   53         ld      h, a
    00000024 78               [ 4]   54         ld      a, b
    00000025 C9               [10]   55         ret
