    00000027 4E               [ 7]   56         ld      c,(hl)                  ; c=count LSB
    00000028 23               [ 6]   57         inc     hl                      ; hl=first line
                                     58         ;; loop through all points, BC=count
    00000029                         59 gpgl_loop:
    00000029 7E               [ 7]   60         ld      a,(hl)                  ; get byte
    0000002A 0B               [ 6]   61         dec     bc                      ; decrease count
    0000002B 23               [ 6]   62         inc     hl                      ; next byte
    0000002C FE 80            [ 7]   63         cp      #ESCAPE                 ; is escape sequence?
    0000002E 28 0E            [12]   64         jr      z,gpgl_escape
                                     65         ;; it's not an escape sequence
    00000030 C5               [11]   66         push    bc                      ; store counter
    00000031 4F               [ 4]   67         ld      c,a                     ; c=dx
    00000032 46               [ 7]   68         ld      b,(hl)                  ; b=dy
    00000033 CD 74 00         [17]   69         call    gpgl_drawline           ; set dx and dy
    00000036 C1               [10]   70         pop     bc                      ; restore counter
    00000037 0B               [ 6]   71         dec     bc                      ; we picked a value from bc
    00000038 23               [ 6]   72         inc     hl                      ; increase ptr.
    00000039 78               [ 4]   73         ld      a,b                     ; if
    0000003A B1               [ 4]   74         or      c
    0000003B 20 EC            [12]   75         jr      nz,gpgl_loop            ; then loop
    0000003D C9               [10]   76         ret
                                     77         ;; NOTE: 
                                     78         ;;      there is no bound check here, the glyph
                                     79         ;;      must be correct!!!
    0000003E                         80 gpgl_escape:
                                     81         ;; first check if we change the color?
    0000003E 7E               [ 7]   82         ld      a,(hl)                  ; command to a
    0000003F E6 02            [ 7]   83         and     #0b00000010             ; bit 1 = set color
    00000041 28 0B            [12]   84         jr      z,pgl_chk_eos           ; no color change
                                     85         ;; let's change color!
    00000043 7E               [ 7]   86         ld      a,(hl)
    00000044 E6 0C            [ 7]   87         and     #0b00001100             ; get the color
    00000046 CB 2F            [ 8]   88         sra     a                       ; color into a
    00000048 CB 2F            [ 8]   89         sra     a                       ; xxxxxxbb
    0000004A 0F               [ 4]   90         rrca                            ; bxxxxxxb
    0000004B CD ED 00         [17]   91         call    gpgt_handle_pen         ; set pen
                                     92         ;; check end of stroke?
    0000004E                         93 pgl_chk_eos:
    0000004E 7E               [ 7]   94         ld      a,(hl)                  ; command to a (again!)
    0000004F E6 01            [ 7]   95         and     #0b00000001             ; bit 0 = end of stroke
    00000051 28 04            [12]   96         jr      z,pgl_eos
                                     97         ;; we don't change the position...
                                     98         ;; ...next 2 parameters are relative.
                                     99         ;; so don't do anything!
    00000053 0B               [ 6]  100         dec     bc
    00000054 23               [ 6]  101         inc     hl
    00000055 18 D2            [12]  102         jr gpgl_loop
    00000057                        103 pgl_eos:
    00000057 0B               [ 6]  104         dec     bc                      ; skip over 0!
    00000058 23               [ 6]  105         inc     hl
    00000059 5E               [ 7]  106         ld      e,(hl)                  ; e=x
    0000005A 0B               [ 6]  107         dec     bc
    0000005B 23               [ 6]  108         inc     hl
    0000005C 56               [ 7]  109         ld      d,(hl)                  ; d=y
    0000005D 0B               [ 6]  110         dec     bc
ASxxxx Assembler V02.00 + NoICE + SDCC mods  (Zilog Z80 / Hitachi HD64180 / ZX-Next / eZ80 / R800)                          Page 3
