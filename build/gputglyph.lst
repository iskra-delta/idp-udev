    0000005E 23               [ 6]  111         inc     hl
    0000005F D5               [11]  112         push    de                      ; store x,y
                                    113         ;; now get x and y and move there!
                                    114         ;; preserve hl and de
    00000060 D9               [ 4]  115         exx
    00000061 C1               [10]  116         pop     bc                      ; b=y, c=x
    00000062 E5               [11]  117         push    hl
    00000063 D5               [11]  118         push    de
    00000064 78               [ 4]  119         ld      a,b                     ; store y
    00000065 06 00            [ 7]  120         ld      b,#0                    ; only dx left in bc
    00000067 09               [11]  121         add     hl,bc                   ; add dx+x
    00000068 EB               [ 4]  122         ex      de,hl                   ; de=X, hl=y
    00000069 4F               [ 4]  123         ld      c,a                     ; bc=y
    0000006A 09               [11]  124         add     hl,bc                   ; hl=Y
    0000006B EB               [ 4]  125         ex      de,hl                   ; de and hl are set
    0000006C CD 00 00         [17]  126         call    gdp_set_xy              ; move to x,y
                                    127         ;; restore origin!
    0000006F D1               [10]  128         pop     de
    00000070 E1               [10]  129         pop     hl
    00000071 D9               [ 4]  130         exx
    00000072 18 B5            [12]  131         jr      gpgl_loop               ; and loop!
    00000074                        132 gpgl_drawline:
                                    133         ;; values are signed! b=dy, c=dx
                                    134         ;; need to create command and run it...
    00000074 16 11            [ 7]  135         ld      d,#0b00010001           ; basic command
    00000076 78               [ 4]  136         ld      a,b                     ; get dy
    00000077 B7               [ 4]  137         or      a                       ; test
    00000078 FA 81 00         [10]  138         jp      m,gpgl_negdy            ; dy is negative
    0000007B 28 07            [12]  139         jr      z,gpgl_dx
                                    140         ;; positive dy but reverse axix
    0000007D 16 15            [ 7]  141         ld      d,#0b00010101           ; command with signed dy!
    0000007F 18 03            [12]  142         jr      gpgl_dx
    00000081                        143 gpgl_negdy:
                                    144         ;; we have reverse y axis so negative is positive
    00000081 ED 44            [ 8]  145         neg                             ; abs. a
    00000083 47               [ 4]  146         ld      b,a                     ; b=abs(dy)
    00000084                        147 gpgl_dx:
    00000084 79               [ 4]  148         ld      a,c                     ; get dx
    00000085 B7               [ 4]  149         or      a
    00000086 FA 8D 00         [10]  150         jp      m,gpgl_negdx            ; dx is negative?
    00000089 1E 00            [ 7]  151         ld      e,#0                    ; OR value for command
    0000008B 18 05            [12]  152         jr      gpgl_draw
    0000008D                        153 gpgl_negdx:
    0000008D ED 44            [ 8]  154         neg                             ; dx is positive
    0000008F 4F               [ 4]  155         ld      c,a                     
    00000090 1E 02            [ 7]  156         ld      e,#0b00000010           ; OR value for command
                                    157         ;; b=dy,c=dx, d or e = cmd
    00000092                        158 gpgl_draw:
    00000092 CD 00 00         [17]  159         call    gdp_set_dxdy
                                    160         ;; command to a
    00000095 7A               [ 4]  161         ld      a,d
    00000096 B3               [ 4]  162         or      e
                                    163         ;; and call command
    00000097 CD 00 00         [17]  164         call    gdp_exec_cmd
    0000009A C9               [10]  165         ret
