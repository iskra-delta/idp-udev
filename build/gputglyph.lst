                                    166         ;; draw tiny glyph
    0000009B                        167 gpg_tiny:
    0000009B CD C9 00         [17]  168         call    gpgt_set_palette        ; get the pallete.
    0000009E                        169 gpgt_moves:
                                    170         ;; extract no of moves
    0000009E 23               [ 6]  171         inc     hl                      ; skip width
    0000009F 23               [ 6]  172         inc     hl                      ; skip height
    000000A0 7E               [ 7]  173         ld      a,(hl)                  ; number of moves
    000000A1 B7               [ 4]  174         or      a                       ; test for zero
    000000A2 C8               [11]  175         ret     z                       ; no moves...
    000000A3 D6 02            [ 7]  176         sub     #2                      ; moves=moves-2
    000000A5 47               [ 4]  177         ld      b,a                     ; b=move counter
                                    178         ;; move to origin
    000000A6 23               [ 6]  179         inc     hl                      ; to origin
    000000A7 5E               [ 7]  180         ld      e,(hl)                  ; e=x
    000000A8 23               [ 6]  181         inc     hl
    000000A9 56               [ 7]  182         ld      d,(hl)                  ; d=y
    000000AA 23               [ 6]  183         inc     hl
    000000AB D5               [11]  184         push    de                      ; store x,y
                                    185         ;; now get x and y and move there!
                                    186         ;; preserve hl and de
    000000AC D9               [ 4]  187         exx
    000000AD C1               [10]  188         pop     bc                      ; b=y, c=x
    000000AE 78               [ 4]  189         ld      a,b                     ; store y
    000000AF 06 00            [ 7]  190         ld      b,#0                    ; only dx left in bc
    000000B1 09               [11]  191         add     hl,bc                   ; add dx+x
    000000B2 EB               [ 4]  192         ex      de,hl                   ; de=X, hl=y
    000000B3 4F               [ 4]  193         ld      c,a                     ; bc=y
    000000B4 09               [11]  194         add     hl,bc                   ; hl=Y
    000000B5 EB               [ 4]  195         ex      de,hl                   ; de and hl are set
    000000B6 CD 00 00         [17]  196         call    gdp_set_xy              ; move to x,y
    000000B9 D9               [ 4]  197         exx
                                    198         ;; and loop hl (pointing to data!)
    000000BA                        199 gpgt_loop:
    000000BA 7E               [ 7]  200         ld      a,(hl)                  ; get move
    000000BB CD ED 00         [17]  201         call    gpgt_handle_pen
    000000BE 23               [ 6]  202         inc     hl
    000000BF F6 81            [ 7]  203         or      #0b10000001             ; set both bits to 1
    000000C1 EE 04            [ 7]  204         xor     #0b00000100             ; negate y sign (rev.axis)
    000000C3 CD 00 00         [17]  205         call    gdp_exec_cmd            ; and draw!
    000000C6 10 F2            [13]  206         djnz    gpgt_loop
    000000C8 C9               [10]  207         ret
    000000C9                        208 gpgt_set_palette:
                                    209         ;; this sets the correct pallete for drawing
                                    210         ;; palette is mapping from currently set ink to 
                                    211         ;; ink inside tiny glyph
                                    212         ;; affects: a, de
    000000C9 AF               [ 4]  213         xor     a
    000000CA 32 07 01         [13]  214         ld      (gpgt_none_value),a
    000000CD E5               [11]  215         push    hl
    000000CE 3A 03 00         [13]  216         ld      a,(gdata+3)             ; get current pen
    000000D1 32 06 01         [13]  217         ld      (gpgt_stored_pen),a     ; and write to cache as init value
    000000D4 21 E5 00         [10]  218         ld      hl, #gpgt_palette       ; get gpgt_palette
    000000D7 16 00            [ 7]  219         ld      d,#0
    000000D9 87               [ 4]  220         add     a                       ; a=a*2
ASxxxx Assembler V02.00 + NoICE + SDCC mods  (Zilog Z80 / Hitachi HD64180 / ZX-Next / eZ80 / R800)                          Page 5
Hexadecimal [32-Bits]



    000000DA 5F               [ 4]  221         ld      e,a                     ; de=2*a
    000000DB 19               [11]  222         add     hl,de                   ; gl points to palette
    000000DC 11 08 01         [10]  223         ld      de,#gpgt_fore_value
    000000DF ED A0            [16]  224         ldi
    000000E1 ED A0            [16]  225         ldi                             ; copy  palette
    000000E3 E1               [10]  226         pop     hl
    000000E4 C9               [10]  227         ret
    000000E5                        228 gpgt_palette:
    000000E5 00 00                  229         .db     0, 0
    000000E7 01 02                  230         .db     1, 2
    000000E9 02 01                  231         .db     2, 1
    000000EB 01 02                  232         .db     1, 2
                                    233         ;; handle pen and color
                                    234         ;; inputs: a is the tiny command
                                    235         ;; affects: de
    000000ED                        236 gpgt_handle_pen:
    000000ED F5               [11]  237         push    af
                                    238         ;; get the pen
    000000EE 07               [ 4]  239         rlca                            ; get color to first 2 bits
    000000EF E6 03            [ 7]  240         and     #0b00000011             ; get color
                                    241         ;; if same as current color, don't do anything expensive
    000000F1 5F               [ 4]  242         ld      e,a
    000000F2 3A 03 00         [13]  243         ld      a,(gdata+3)
    000000F5 BB               [ 4]  244         cp      e
    000000F6 28 0C            [12]  245         jr      z, gpgtp_end
                                    246         ;; map to palette
    000000F8 E5               [11]  247         push    hl                      ; store hl
    000000F9 21 07 01         [10]  248         ld      hl,#gpgt_none_value     ; hl=assume
    000000FC 16 00            [ 7]  249         ld      d,#0                    ; de=a (index)
    000000FE 19               [11]  250         add     hl,de                   ; point to color
    000000FF 6E               [ 7]  251         ld      l,(hl)                  ; l=color
                                    252         ;; prepare args for the call!
    00000100 CD 00 00         [17]  253         call    gsc_raw
                                    254         ;; restore original hl
    00000103 E1               [10]  255         pop     hl
    00000104                        256 gpgtp_end:
    00000104 F1               [10]  257         pop     af
    00000105 C9               [10]  258         ret
                                    259 
                                    260         ;; place to store cached values
    00000106                        261 gpgt_stored_pen:
    00000106 00                     262         .db     0
    00000107                        263 gpgt_none_value:
    00000107 00                     264         .db     0
    00000108                        265 gpgt_fore_value:
    00000108 01                     266         .db     1
    00000109                        267 gpgt_back_value:
    00000109 02                     268         .db     2
