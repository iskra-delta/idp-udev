                                      9         .module gputglyph
                                     10 
                                     11         .globl  _gputglyph
                                     12         .globl  gpg_raw
                                     13         .globl  gpgt_set_palette
                                     14 
                         FFFFFF80    15         .equ    ESCAPE,-128
                                     16 
                                     17         .area    _CODE
                                     18         ;; ---------------------------------------------
                                     19         ;; void gputglyph(void* glyph, coord x, coord y)
                                     20         ;; ---------------------------------------------
                                     21         ;; draws glyph at x,y without clipping!
                                     22         ;; recognizes standard glyphs from libgpx
    00000000                         23 _gputglyph:
                                     24         ;;  hl=void * (glyph) - already in HL
                                     25         ;;  hl'=x - from DE
                                     26         ;;  de'=y - from stack
    00000000 DD 21 00 00      [14]   27         ld      ix,#0
    00000004 DD 39            [15]   28         add     ix,sp
    00000006 D9               [ 4]   29         exx
    00000007 EB               [ 4]   30         ex      de,hl                   ; hl'=x (from DE parameter)
    00000008 DD 5E 00         [19]   31         ld      e,(ix)                  ; de'=y from stack
    0000000B DD 56 01         [19]   32         ld      d,1(ix)
    0000000E D9               [ 4]   33         exx
                                     34         ;; HL contains glyph pointer, alternate regs contain x,y
    0000000F                         35 gpg_raw:
                                     36         ;; now get number of bytes into bc
    0000000F 7E               [ 7]   37         ld      a,(hl)                  ; get sprite signature
    00000010 23               [ 6]   38         inc     hl                      ; next byte...
                                     39         ;; recognize glyph type
    00000011 47               [ 4]   40         ld      b,a                     ; store to b
    00000012 E6 E0            [ 7]   41         and     #0b11100000             ; only leave signature
    00000014 FE 40            [ 7]   42         cp      #0b01000000             ; test for lines glyph
    00000016 28 06            [12]   43         jr      z,gpg_lines
    00000018 FE 20            [ 7]   44         cp      #0b00100000             ; test for tiny glyph
    0000001A CA 9B 00         [10]   45         jp      z,gpg_tiny
                                     46         ;; if we're here, we failed to recognize the glyph!
    0000001D C9               [10]   47         ret
                                     48         ;; draw lines glyph
    0000001E                         49 gpg_lines:
    0000001E CD C9 00         [17]   50         call    gpgt_set_palette        ; get the pallete.
    00000021 78               [ 4]   51         ld      a,b                     ; restore a
    00000022 E6 0F            [ 7]   52         and     #0x0f                   ; a=msb
    00000024 47               [ 4]   53         ld      b,a                     ; b=msb
    00000025 23               [ 6]   54         inc     hl                      ; skip width
    00000026 23               [ 6]   55         inc     hl                      ; skip height
ASxxxx Assembler V02.00 + NoICE + SDCC mods  (Zilog Z80 / Hitachi HD64180 / ZX-Next / eZ80 / R800)                          Page 2
