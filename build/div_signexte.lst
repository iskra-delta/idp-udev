                                      5 
                                      6         .module div_signexte
                                      7         .optsdcc -mz80 sdcccall(1)
                                      8 
                                      9         .globl  __div_signexte
                                     10         .globl  __div16
                                     11         .area   _CODE
                                     12 
    00000000                         13 __div_signexte::
    00000000 7B               [ 4]   14         ld      a, e
    00000001 07               [ 4]   15         rlca
    00000002 9F               [ 4]   16         sbc     a, a
    00000003 57               [ 4]   17         ld      d, a
    00000004 C3 00 00         [10]   18         jp      __div16
