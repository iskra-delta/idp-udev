                                     16 
                                     17         .area    _CODE
                                     18 
                                     19         ;; ---------------------
                                     20         ;; void gdrawline(
                                     21         ;;     unsigned int  x0,
                                     22         ;;     unsigned int  y0,
                                     23         ;;     unsigned int  x1,
                                     24         ;;     unsigned int  y1)
                                     25         ;; ---------------------
    00000000                         26 _gdrawline:
                                     27         ;; Need to set up stack so IY can access all parameters
                                     28         ;; Stack layout needed by gdrawlineraw:
                                     29         ;;   IY+0,1 = x0
                                     30         ;;   IY+2,3 = y0
                                     31         ;;   IY+4,5 = x1 (already at SP+0)
                                     32         ;;   IY+6,7 = y1 (already at SP+2)
                                     33         ;; Push y0 and x0 to complete the layout
    00000000 D5               [11]   34         push    de                      ; push y0
    00000001 E5               [11]   35         push    hl                      ; push x0
                                     36         ;; Now stack has: [x0][y0][x1][y1]
    00000002 FD 21 00 00      [14]   37         ld      iy,#0
    00000006 FD 39            [15]   38         add     iy,sp                   ; IY points to x0
                                     39         ;; to support HW patterns we'll draw line
                                     40         ;; from back to front!
    00000008                         41 gdrawlineraw:
                                     42         ;; first calculate dx
    00000008 FD 6E 04         [19]   43         ld      l,4(iy)                 ; hl=x1
    0000000B FD 66 05         [19]   44         ld      h,5(iy)         
    0000000E FD 5E 00         [19]   45         ld      e,(iy)                  ; de=x0
    00000011 FD 56 01         [19]   46         ld      d,1(iy)
    00000014 B7               [ 4]   47         or      a                       ; clear carry
    00000015 ED 52            [15]   48         sbc     hl,de                   ; hl=dx
    00000017 E5               [11]   49         push    hl                      ; store dx
                                     50         ;; now goto x,y
    00000018 EB               [ 4]   51         ex      de,hl                   ; hl=x0
    00000019 FD 5E 02         [19]   52         ld      e,2(iy)                 ; de=y0
    0000001C FD 56 03         [19]   53         ld      d,3(iy)     
    0000001F CD 00 00         [17]   54         call    gdp_set_xy
                                     55         ;; and calc dy
    00000022 FD 6E 06         [19]   56         ld      l,6(iy)                 ; hl=y1
    00000025 FD 66 07         [19]   57         ld      h,7(iy)
    00000028 B7               [ 4]   58         or      a
    00000029 ED 52            [15]   59         sbc     hl,de                   ; hl=dy
    0000002B EB               [ 4]   60         ex      de,hl                   ; de=dy
    0000002C E1               [10]   61         pop     hl                      ; hl=dx
                                     62         ;; get commnad into a
    0000002D CD 00 00         [17]   63         call    gdp_get_delta_cmd
    00000030 4F               [ 4]   64         ld      c,a                     ; store a to c
                                     65         ;; we have the draw command
    00000031 CD 00 00         [17]   66         call    abs_hl                  
    00000034 EB               [ 4]   67         ex      de,hl
    00000035 CD 00 00         [17]   68         call    abs_hl                  ; hl=abs(dy), de=abs(dy)
    00000038 D5               [11]   69         push    de                      ; push dx
    00000039 E5               [11]   70         push    hl                      ; push dy
ASxxxx Assembler V02.00 + NoICE + SDCC mods  (Zilog Z80 / Hitachi HD64180 / ZX-Next / eZ80 / R800)                          Page 5
Hexadecimal [32-Bits]



    0000003A 06 01            [ 7]   71         ld      b,#1                    ; 1 item on stack
    0000003C                         72 gdl_recurse:
                                     73         ;; get dx and dy
    0000003C D1               [10]   74         pop     de                      ; dy first
    0000003D E1               [10]   75         pop     hl                      ; now dx
                                     76         ;; test if both <= 255
    0000003E 7A               [ 4]   77         ld      a,d
    0000003F B4               [ 4]   78         or      h
    00000040 20 12            [12]   79         jr      nz, gld_divide
                                     80         ;; if we are here, draw delta!
    00000042 CD 00 00         [17]   81         call    gdp_wait_ready          ; first wait
    00000045 7D               [ 4]   82         ld      a,l                     ; l=dx
    00000046 D3 25            [11]   83         out     (#EF9367_DX),a
    00000048 7B               [ 4]   84         ld      a,e                     ; e=dy
    00000049 D3 27            [11]   85         out     (#EF9367_DY),a
    0000004B 79               [ 4]   86         ld      a,c                     ; command
    0000004C CD 00 00         [17]   87         call    gdp_exec_cmd            ; draw!
    0000004F 10 EB            [13]   88         djnz    gdl_recurse
                                     89         ;; cleanup stack (pop x0 and y0 that we pushed)
    00000051 E1               [10]   90         pop     hl
    00000052 E1               [10]   91         pop     hl
    00000053 C9               [10]   92         ret
    00000054                         93 gld_divide:
                                     94         ;; divide hl and de to half
    00000054 7D               [ 4]   95         ld      a,l                     ; get hl % 2
    00000055 E6 01            [ 7]   96         and     #1                      ; into a
    00000057 FD 77 00         [19]   97         ld      (iy),a                  ; store to stack
    0000005A CB 3C            [ 8]   98         srl     h                       ; hl=hl/2
    0000005C CB 1D            [ 8]   99         rr      l
    0000005E E5               [11]  100         push    hl                      ; first dx
    0000005F 7B               [ 4]  101         ld      a,e                     ; get de % 2
    00000060 E6 01            [ 7]  102         and     #1                      ; into a
    00000062 FD 77 01         [19]  103         ld      1(iy),a                 ; store a on stack
    00000065 CB 3A            [ 8]  104         srl     d                       ; de=de/2
    00000067 CB 1B            [ 8]  105         rr      e
    00000069 D5               [11]  106         push    de                      ; then dy
    0000006A 04               [ 4]  107         inc     b                       ; one more on stack
                                    108         ;; second half and (possible) remainder
    0000006B 3E 01            [ 7]  109         ld      a,#1
    0000006D FD BE 00         [19]  110         cp      (iy)
    00000070 20 01            [12]  111         jr      nz,gld_div_xr
    00000072 23               [ 6]  112         inc     hl
    00000073                        113 gld_div_xr:
    00000073 E5               [11]  114         push    hl
    00000074 FD BE 01         [19]  115         cp      1(iy)
    00000077 20 01            [12]  116         jr      nz,gld_div_yr
    00000079 13               [ 6]  117         inc     de
    0000007A                        118 gld_div_yr:
    0000007A D5               [11]  119         push    de
    0000007B 04               [ 4]  120         inc     b
    0000007C 10 BE            [13]  121         djnz    gdl_recurse
                                    122         ;; cleanup stack (pop x0 and y0 that we pushed)
    0000007E E1               [10]  123         pop     hl
    0000007F E1               [10]  124         pop     hl
    00000080 C9               [10]  125         ret
