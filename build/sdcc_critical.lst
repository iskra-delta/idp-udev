                                      5 
                                      6         .module critical
                                      7         .optsdcc -mz80 sdcccall(1)
                                      8 
                                      9         .globl  ___sdcc_critical
                                     10         .globl  __sdcc_critical
                                     11         .area   _CODE
                                     12 
    00000000                         13 ___sdcc_critical:
    00000000                         14 __sdcc_critical:
    00000000 ED 57            [ 9]   15         ld      a, i
    00000002 F3               [ 4]   16         di
    00000003 C9               [10]   17         ret
