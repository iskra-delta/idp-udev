                         00000030    69         .equ    PIO_GR_CMN,             0x30
ASxxxx Assembler V02.00 + NoICE + SDCC mods  (Zilog Z80 / Hitachi HD64180 / ZX-Next / eZ80 / R800)                          Page 4
Hexadecimal [32-Bits]



                                     23 
                                     24         .area    _CODE
                                     25         ;; wait for the GDP to finish previous operation
                                     26         ;; don't touch interrupts!
                                     27         ;; affects: a
    00000000                         28 gdp_wait_ready:
                                     29         ;; make sure GDP is free
    00000000 DB 2F            [11]   30         in      a,(EF9367_STS_NI)       ; read the status register
    00000002 E6 04            [ 7]   31         and     #EF9367_STS_NI_READY    ; get ready flag, it's the same bit
    00000004 28 FA            [12]   32         jr      z,gdp_wait_ready
    00000006 C9               [10]   33         ret
                                     34 
                                     35         ;; wait for VBL
                                     36         ;; affects: a
    00000007                         37 gdp_wait_vbl:
    00000007 DB 2F            [11]   38         in      a,(EF9367_STS_NI)
    00000009 E6 02            [ 7]   39         and     #EF9367_STS_NI_VBLANK
    0000000B 28 FA            [12]   40         jr      z,gdp_wait_vbl
    0000000D C9               [10]   41         ret
                                     42 
                                     43         ;; execute command in a
                                     44         ;; input:    a=command
                                     45         ;; affects: -
    0000000E                         46 gdp_exec_cmd:
    0000000E F5               [11]   47         push    af
    0000000F CD 00 00         [17]   48         call    gdp_wait_ready        ; wait gdp
    00000012 F1               [10]   49         pop     af
    00000013 D3 20            [11]   50         out     (#EF9367_CMD), a        ; exec. command
    00000015 C9               [10]   51         ret
                                     52 
                                     53         ;; set deltas to dx, dy
                                     54         ;; inputs:  b=dy, c=dx
                                     55         ;; affect:  a
    00000016                         56 gdp_set_dxdy:
    00000016 CD 00 00         [17]   57         call    gdp_wait_ready
    00000019 78               [ 4]   58         ld      a,b
    0000001A D3 27            [11]   59         out     (#EF9367_DY),a
    0000001C 79               [ 4]   60         ld      a,c
    0000001D D3 25            [11]   61         out     (#EF9367_DX),a
    0000001F C9               [10]   62         ret
                                     63 
                                     64         ;; move the cursor to x,y
                                     65         ;; notes:   y is transformed (ef9367 has negative axis!
                                     66         ;; inputs:  hl=x, de=y
                                     67         ;; affect:  af
    00000020                         68 gdp_set_xy:
                                     69         ;; store hl and de regs
    00000020 D5               [11]   70         push    de
    00000021 E5               [11]   71         push    hl
                                     72         ;; reverse y coordinate
    00000022 E5               [11]   73         push    hl                      ; store x
    00000023 2A 00 00         [16]   74         ld      hl,(gdata)              ; hl=height
    00000026 2B               [ 6]   75         dec     hl                      ; -1
    00000027 B7               [ 4]   76         or      a                       ; clear carry
    00000028 ED 52            [15]   77         sbc     hl,de                   ; hl=maxy-y
ASxxxx Assembler V02.00 + NoICE + SDCC mods  (Zilog Z80 / Hitachi HD64180 / ZX-Next / eZ80 / R800)                          Page 5
Hexadecimal [32-Bits]



    0000002A D1               [10]   78         pop     de                      ; de=x
    0000002B EB               [ 4]   79         ex      de,hl                   ; switch
                                     80         ;; wait for gdp
    0000002C CD 00 00         [17]   81         call    gdp_wait_ready
    0000002F 7D               [ 4]   82         ld      a,l
    00000030 D3 29            [11]   83         out     (EF9367_XPOS_LO),a
    00000032 7C               [ 4]   84         ld      a,h
    00000033 D3 28            [11]   85         out     (EF9367_XPOS_HI),a
    00000035 7B               [ 4]   86         ld      a,e
    00000036 D3 2B            [11]   87         out     (EF9367_YPOS_LO),a
    00000038 7A               [ 4]   88         ld      a,d
    00000039 D3 2A            [11]   89         out     (EF9367_YPOS_HI),a
                                     90         ;; restore de and hl
    0000003B E1               [10]   91         pop     hl
    0000003C D1               [10]   92         pop     de
    0000003D C9               [10]   93         ret
                                     94 
                                     95         ;; given 16 bit signed
                                     96         ;; dx and dy, this routine
                                     97         ;; returns a command to draw
                                     98         ;; NOTE:
                                     99         ;;  dx and dy are not limited to 255
                                    100         ;;  for this function, they must be
                                    101         ;;  signed 16 bit numbers
                                    102         ;; a delta line in a
                                    103         ;; inputs:  hl=dx, de=dy
                                    104         ;; output:  a=delta command
                                    105         ;; affects: af, bc
    0000003E                        106 gdp_get_delta_cmd:
                                    107         ;; first grab both sign bits
    0000003E 7C               [ 4]  108         ld      a,h                     ; check if hl is neg.
    0000003F E6 80            [ 7]  109         and     #0b10000000             ; sign bit?
    00000041 07               [ 4]  110         rlca                            ; rotate sign bit to...
    00000042 07               [ 4]  111         rlca                            ; ...bit 1
    00000043 47               [ 4]  112         ld      b,a                     ; store sign of x
    00000044 7A               [ 4]  113         ld      a,d                     ; the same for de...
    00000045 E6 80            [ 7]  114         and     #0b10000000
    00000047 07               [ 4]  115         rlca                            
    00000048 07               [ 4]  116         rlca
    00000049 07               [ 4]  117         rlca
    0000004A 4F               [ 4]  118         ld      c,a                     ; store sign of y
                                    119         ;; now find out if dx=0 or dy=0
    0000004B 7C               [ 4]  120         ld      a,h
    0000004C B5               [ 4]  121         or      l
    0000004D 28 0B            [12]  122         jr      z,gdp_gd_ign_dx         ; ignore dx?
    0000004F 7A               [ 4]  123         ld      a,d
    00000050 B3               [ 4]  124         or      e
    00000051 28 0F            [12]  125         jr      z,gdp_gd_ign_dy         ; ignore dy?
                                    126         ;; if we are here there's no ignore so
                                    127         ;; create command in a
                                    128         ;; NOTE: because y is reverse axis, you need
                                    129         ;;       to invert dy sign bit!
    00000053 3E 11            [ 7]  130         ld      a,#0b00010001           ; draw command
    00000055 B0               [ 4]  131         or      b                       ; add dx sign
    00000056 B1               [ 4]  132         or      c                       ; add dy sign
ASxxxx Assembler V02.00 + NoICE + SDCC mods  (Zilog Z80 / Hitachi HD64180 / ZX-Next / eZ80 / R800)                          Page 6
Hexadecimal [32-Bits]



    00000057 EE 04            [ 7]  133         xor     #0b00000100             ; invert dy bit
    00000059 C9               [10]  134         ret
                                    135         ;; ignore dx command...
    0000005A                        136 gdp_gd_ign_dx:
    0000005A 79               [ 4]  137         ld      a,c                     ; dy to a
    0000005B 0F               [ 4]  138         rrca                            ; move into dx
    0000005C B1               [ 4]  139         or      c                       ; set dy again!
    0000005D EE 04            [ 7]  140         xor     #0b00000100             ; negate it (neg. axis)
    0000005F F6 10            [ 7]  141         or      #0b00010000             ; and set the command bit
    00000061 C9               [10]  142         ret
    00000062                        143 gdp_gd_ign_dy:
    00000062 78               [ 4]  144         ld      a,b                     ; dx to a
    00000063 07               [ 4]  145         rlca                            ; move into dy
    00000064 B0               [ 4]  146         or      b                       ; set dx again!
    00000065 F6 10            [ 7]  147         or      #0b00010000             ; and set the command bit
    00000067 C9               [10]  148         ret
                                    149 
