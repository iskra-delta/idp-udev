                                      9         .module bdos
                                     10 
                                     11         .globl _bdos
                                     12         .globl _bdosret
                                     13 
                         00000005    14         .equ    BDOS, 5
                                     15 
                                     16         .area _CODE
                                     17 
                                     18 
                                     19         ;; ---------------------------------------------------------
                                     20         ;; unsigned char bdos(unsigned char fn, unsigned int param);
                                     21         ;; ---------------------------------------------------------
                                     22         ;; calls cp/m bdos
                                     23         ;; affect:  af, bc, de, hl
    00000000                         24 _bdos::
    00000000 DD E5            [15]   25         push    ix                      ; store ix
    00000002 4D               [ 4]   26         ld      c,l                     ; fn to C for BDOS call
                                     27         ;; DE already contains param
    00000003 CD 05 00         [17]   28         call    BDOS                    ; make BDOS call
    00000006 DD E1            [14]   29         pop     ix                      ; restore ix
    00000008 6F               [ 4]   30         ld      l,a                     ; return a
    00000009 C9               [10]   31         ret
                                     32 
                                     33 
                                     34         ;; -------------------------------------------------------------------------
                                     35         ;; bdos_ret_t *bdosret(unsigned char fn, unsigned int param, bdos_ret_t *p);
                                     36         ;; -------------------------------------------------------------------------
                                     37         ;; calls cp/m bdos and store result to variables
                                     38         ;; output: a, b, hl populated with ret. values
                                     39         ;; affect:  af, bc, de, hl
    0000000A                         40 _bdosret::
    0000000A DD E5            [15]   41         push    ix                      ; save ix
    0000000C 4D               [ 4]   42         ld      c,l                     ; fn to C for BDOS
                                     43         ;; DE already contains param
                                     44         ;; Save DE before BDOS call (we need it later)
    0000000D D5               [11]   45         push    de
    0000000E CD 05 00         [17]   46         call    BDOS                    ; make BDOS call
                                     47         ;; BDOS returns: A, B, DE (sometimes HL)
    00000011 D1               [10]   48         pop     de                      ; restore original param to DE
                                     49         ;; Now get p pointer from stack
                                     50         ;; Stack: [IX][ret_addr][p_lo][p_hi]
    00000012 DD 21 04 00      [14]   51         ld      ix,#4                   ; skip over saved IX (2) and return addr (2)
    00000016 DD 39            [15]   52         add     ix,sp
    00000018 DD 6E 00         [19]   53         ld      l,(ix)                  ; p pointer from stack
    0000001B DD 66 01         [19]   54         ld      h,1(ix)
    0000001E E5               [11]   55         push    hl                      ; store pointer as return value
ASxxxx Assembler V02.00 + NoICE + SDCC mods  (Zilog Z80 / Hitachi HD64180 / ZX-Next / eZ80 / R800)                          Page 2
Hexadecimal [32-Bits]



                                     56         ;; Store BDOS results to structure pointed by HL
    0000001F 77               [ 7]   57         ld      (hl),a                  ; store a
    00000020 23               [ 6]   58         inc     hl
    00000021 70               [ 7]   59         ld      (hl),b                  ; store b
    00000022 23               [ 6]   60         inc     hl
                                     61         ;; DE from BDOS is in DE, but we need the original DE which we popped
                                     62         ;; Actually, looking at the old code, it uses ex de,hl to store the result
                                     63         ;; The BDOS result HL goes to DE, then stored. Let me check the old code again.
                                     64         ;; Old code: ex de,hl means BDOS's HL result goes to DE for storage
                                     65         ;; Since BDOS can return in HL, save that
    00000023 EB               [ 4]   66         ex      de,hl                   ; BDOS result HL to DE
    00000024 73               [ 7]   67         ld      (hl),e                  ; store hl result
    00000025 23               [ 6]   68         inc     hl
    00000026 72               [ 7]   69         ld      (hl),d
                                     70         ;; restore return value
    00000027 E1               [10]   71         pop     hl
                                     72         ;; clean stack and exit
    00000028 DD E1            [14]   73         pop     ix                      ; restore ix
    0000002A C9               [10]   74         ret
