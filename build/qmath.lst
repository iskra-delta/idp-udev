                                      9         .module qmath
                                     10 
                                     11         .globl  abs_hl
                                     12 
                                     13         .area    _CODE
                                     14         ;; calculates absolute value of hl
                                     15         ;; inputs:  hl
                                     16         ;; outputs: hl = abs(hl)
                                     17         ;; affect:  af, hl
    00000000                         18 abs_hl:
    00000000 CB 7C            [ 8]   19         bit     7,h
    00000002 C8               [11]   20         ret     z
    00000003 AF               [ 4]   21         xor     a  
    00000004 95               [ 4]   22         sub     l 
    00000005 6F               [ 4]   23         ld      l,a
    00000006 9F               [ 4]   24         sbc     a,a 
    00000007 94               [ 4]   25         sub     h 
    00000008 67               [ 4]   26         ld      h,a
    00000009 C9               [10]   27         ret
