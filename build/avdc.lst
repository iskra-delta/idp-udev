                                     16 
                                     17         .area    _CODE
                                     18 
                                     19 
                                     20         ;; ----- support functions --------------------------------------------
                                     21 
                                     22         ;; wait for avdc int
                                     23         ;; affects: af
    00000000                         24 avdc_wait_mem_acc:
                                     25         ;; if low, wait for high
    00000000 DB 36            [11]   26         in      a, (#SCN2674_GR_CMNI)
    00000002 E6 10            [ 7]   27         and     #SCN2674_GR_CMNI_SCN2674A
    00000004 28 FA            [12]   28         jr      z,avdc_wait_mem_acc
                                     29         ;; ...wait for high to end
    00000006                         30 awint:
    00000006 DB 36            [11]   31         in      a, (#SCN2674_GR_CMNI)
    00000008 E6 10            [ 7]   32         and     #SCN2674_GR_CMNI_SCN2674A
    0000000A 20 FA            [12]   33         jr      nz,awint
    0000000C C9               [10]   34         ret
                                     35 
                                     36         ;; wait for avdc ready
                                     37         ;; affects: af
    0000000D                         38 avdc_wait_rdy:
    0000000D DB 39            [11]   39         in      a,(#SCN2674_STS)
    0000000F E6 20            [ 7]   40         and     #SCN2674_STS_RDY
    00000011 28 FA            [12]   41         jr      z,avdc_wait_rdy
    00000013 C9               [10]   42         ret
                                     43 
                                     44         ;; write hl to cursor
    00000014                         45 avdc_hl2cursor:
    00000014 CD 0D 00         [17]   46         call    avdc_wait_rdy
                                     47         ;; set cursor
    00000017 7D               [ 4]   48         ld      a,l
    00000018 D3 3C            [11]   49         out     (#SCN2674_CUR_LO),a
    0000001A 7C               [ 4]   50         ld      a,h
    0000001B D3 3D            [11]   51         out     (#SCN2674_CUR_HI),a
    0000001D C9               [10]   52         ret
                                     53 
                                     54         ;; write cursor to hl
    0000001E                         55 avdc_cursor2hl:
    0000001E CD 0D 00         [17]   56         call    avdc_wait_rdy
                                     57         ;; get cursor
    00000021 DB 3C            [11]   58         in      a,(#SCN2674_CUR_LO)
    00000023 6F               [ 4]   59         ld      l,a
    00000024 DB 3D            [11]   60         in      a,(#SCN2674_CUR_HI)
    00000026 67               [ 4]   61         ld      h,a
    00000027 C9               [10]   62         ret
                                     63 
                                     64         ;; write hl to pointer
                                     65         ;; affects: af
    00000028                         66 avdc_hl2pointer:
    00000028 CD 0D 00         [17]   67         call    avdc_wait_rdy
                                     68         ;; set pointer to correct row ptr address.
    0000002B 3E 1A            [ 7]   69         ld      a,#0x1A                 ; set IR to A (10)
    0000002D D3 39            [11]   70         out     (#SCN2674_CMD), a       ; command!
ASxxxx Assembler V02.00 + NoICE + SDCC mods  (Zilog Z80 / Hitachi HD64180 / ZX-Next / eZ80 / R800)                          Page 5
Hexadecimal [32-Bits]



    0000002F 7D               [ 4]   71         ld      a,l
    00000030 D3 38            [11]   72         out     (#SCN2674_INIT),a       ; pointer low
    00000032 7C               [ 4]   73         ld      a,h
    00000033 D3 38            [11]   74         out     (#SCN2674_INIT),a       ; pointer high
    00000035 C9               [10]   75         ret
                                     76 
                                     77         ;; avdc_read
                                     78         ;; read SCN (video!) memory and attr at hl
                                     79         ;; NOTES:
                                     80         ;;  must be preceeded by avdc_wait_int and
                                     81         ;;  avdc_wait_rdy!
                                     82         ;; inputs:  hl=memory address
                                     83         ;; outputs: e=char, d=attribute
                                     84         ;; affects: af, de
    00000036                         85 avdc_read:
    00000036 CD 28 00         [17]   86         call    avdc_hl2pointer    
                                     87         ;; read char into a
    00000039 3E A4            [ 7]   88         ld      a,#SCN2674_CMD_RDPTR    ; read at pointer
    0000003B D3 39            [11]   89         out     (SCN2674_CMD), a        ; read into char reg.    
    0000003D CD 0D 00         [17]   90         call    avdc_wait_rdy           ; makes sure we're done
    00000040 DB 34            [11]   91         in      a,(SCN2674_CHR)         ; get char
    00000042 5F               [ 4]   92         ld      e,a                     ; char into e
    00000043 DB 35            [11]   93         in      a,(SCN2674_AT)          ; get attr
    00000045 57               [ 4]   94         ld      d,a                     ; into d
    00000046 C9               [10]   95         ret
                                     96 
                                     97         ;; avdc_rowptr (l=row index) into hl
                                     98         ;; returns row address
                                     99         ;; NOTES:
                                    100         ;;  on idp a row table mode is used to access
                                    101         ;;  rows. row table spans from addr 0 to addr 52.
                                    102         ;;  this is enough to store pointers for 26
                                    103         ;;  rows (2 bytes per pointer).
                                    104         ;;  each row is 132 characters wide.
                                    105         ;; inputs: l=row index
                                    106         ;; outputs: hl=row address
                                    107         ;; affects: hl, de, af
    00000047                        108 avdc_rowptr:
                                    109         ;; calculate exact row addr
    00000047 26 00            [ 7]  110         ld      h, #0                   ; hl=row
    00000049 29               [11]  111         add     hl,hl                   ; hl=hl*2
                                    112         ;; wait for interrupt
                                    113         ;; read it
    0000004A CD 36 00         [17]  114         call    avdc_read               ; read first byte
    0000004D D5               [11]  115         push    de                      ; store result
    0000004E 23               [ 6]  116         inc     hl                      ; addr+1
    0000004F CD 36 00         [17]  117         call    avdc_read               ; and read to de
    00000052 63               [ 4]  118         ld      h,e
    00000053 D1               [10]  119         pop     de
    00000054 6B               [ 4]  120         ld      l,e
    00000055 C9               [10]  121         ret  
                                    122 
                                    123 
                                    124         ;; ----- functions ----------------------------------------------------
                                    125 
ASxxxx Assembler V02.00 + NoICE + SDCC mods  (Zilog Z80 / Hitachi HD64180 / ZX-Next / eZ80 / R800)                          Page 6
Hexadecimal [32-Bits]



                                    126         ;; clear screen
    00000056                        127 avdc_cls:
    00000056 06 1A            [ 7]  128         ld      b,#26                   ; 26 rows
    00000058 21 00 00         [10]  129         ld      hl,#0                   ; row #
    0000005B                        130 scls_loop:
                                    131         ;; wait access
    0000005B CD 00 00         [17]  132         call    avdc_wait_mem_acc
                                    133         ;; row to hl
    0000005E 26 00            [ 7]  134         ld      h,#0
    00000060 68               [ 4]  135         ld      l,b                     ; b=row
    00000061 2D               [ 4]  136         dec     l                       ; make l 0 based index
    00000062 CD 47 00         [17]  137         call    avdc_rowptr             ; row pointer 2 hl
                                    138         ;; now move cursor to hl
    00000065 CD 14 00         [17]  139         call    avdc_hl2cursor          ; set cursor to start
    00000068 11 83 00         [10]  140         ld      de,#131                 ; row length
    0000006B 19               [11]  141         add     hl,de                   ; add to hl
    0000006C CD 28 00         [17]  142         call    avdc_hl2pointer         ; set pointer to end
                                    143         ;; set char
    0000006F CD 0D 00         [17]  144         call    avdc_wait_rdy
    00000072 3E 20            [ 7]  145         ld      a,#32                   ; space
    00000074 D3 34            [11]  146         out     (#SCN2674_CHR),a
    00000076 AF               [ 4]  147         xor     a                       ; attr=0
    00000077 D3 35            [11]  148         out     (#SCN2674_AT),a
                                    149         ;; finally, delete from cursor to pointer
    00000079 3E BB            [ 7]  150         ld      a,#SCN2674_CMD_WC2P
    0000007B D3 39            [11]  151         out     (#SCN2674_CMD), a       ; write from curs. to ptr.
                                    152         ;; next row
    0000007D 10 DC            [13]  153         djnz    scls_loop
                                    154         ;; move cursor to 0,0
    0000007F 2E 00            [ 7]  155         ld      l,#0
    00000081 CD 47 00         [17]  156         call    avdc_rowptr
    00000084 CD 14 00         [17]  157         call    avdc_hl2cursor
    00000087 C9               [10]  158         ret
                                    159 
                                    160         ;; show cursor
    00000088                        161 avdc_show_cursor:
    00000088 CD 00 00         [17]  162         call    avdc_wait_mem_acc
    0000008B 3E 31            [ 7]  163         ld      a, #SCN2674_CMD_CURS_ON
    0000008D D3 39            [11]  164         out     (SCN2674_CMD), a
    0000008F C9               [10]  165         ret
                                    166 
                                    167         ;; hide cursor
    00000090                        168 avdc_hide_cursor:
    00000090 CD 00 00         [17]  169         call    avdc_wait_mem_acc
    00000093 3E 30            [ 7]  170         ld      a, #SCN2674_CMD_CURS_OFF
    00000095 D3 39            [11]  171         out     (SCN2674_CMD), a
    00000097 C9               [10]  172         ret
