                                     10         ;; --- 0x34 - R/W:character register ----------------------------------
                         00000034    11         .equ SCN2674_CHR,               0x34
                                     12 
                                     13         
                                     14         ;; --- 0x35 - R/W:attribute register ----------------------------------
                         00000035    15         .equ SCN2674_AT,                0x35
                         00000000    16         .equ SCN2674_AT_NONE,           0x00    ; no attributes
                         00000001    17         .equ SCN2674_AT_BLINK,          0x01    ; blink
                         00000002    18         .equ SCN2674_AT_UNDERLINE,      0x02    ; underline
                         00000004    19         .equ SCN2674_AT_SPC_CHR,        0x04    ; special character
                         00000008    20         .equ SCN2674_AT_PROTECT,        0x08    ; protect
                         00000010    21         .equ SCN2674_AT_HIGHLIGHT,      0x10    ; R:highlight, W:red foreground
                         00000020    22         .equ SCN2674_AT_REVERSE,        0x20    ; R:reverse, W:green background
                         00000040    23         .equ SCN2674_AT_GP2,            0x40    ; R:GP 2, W:blue background
                         00000080    24         .equ SCN2674_AT_GP1,            0x80    ; R:GP 1, W:red background
                                     25 
                                     26 
                                     27         ;; --- 0x36 - W:gr.scroll (byte value=scan lines), R:common input -----
                         00000036    28         .equ SCN2674_GR_SCROLL,         0x36
                                     29 
                         00000036    30         .equ SCN2674_GR_CMNI,           0x36    ; same register, different name
                         00000010    31         .equ SCN2674_GR_CMNI_SCN2674A,  0x10    ; SCN2674 access flag
                         00000080    32         .equ SCN2674_GR_CMNI_PIX,       0x80    ; graph. pix input
                                     33 
                                     34 
                                     35         ;; --- 0x38 - W:init (all 15 init reg. sequentially accessed) --------- 
                                     36         ;; R:interrupt (bits 7-6 default 0)
                         00000038    37         .equ SCN2674_INIT,              0x38
                         00000038    38         .equ SCN2674_IR,                0x38    ; same register, different name
                         00000001    39         .equ SCN2674_IR_SS2,            0x01    ; split screen 2 interrupt
                         00000002    40         .equ SCN2674_IR_RDY,            0x02    ; ready interrupt
                         00000004    41         .equ SCN2674_IR_SS1,            0x04    ; split screen 1 interrupt
                         00000008    42         .equ SCN2674_IR_LZ,             0x08    ; line zero interrupt
                         00000010    43         .equ SCN2674_IR_VB,             0x10    ; vblank int
                                     44 
                                     45 
                                     46         ;; --- 0x39 - W:command (byte is command) -----------------------------
                                     47         ;; R:status (bits 7-5 default 0)
                         00000039    48         .equ SCN2674_CMD,               0x39    
                         00000000    49         .equ SCN2674_CMD_RESET,         0x00    ; master reset
                         00000010    50         .equ SCN2674_CMD_SET_IR,        0x10    ; set IR pointer to lower nibble
                         00000030    51         .equ SCN2674_CMD_CURS_OFF,      0x30    ; switch off cursor
                         00000031    52         .equ SCN2674_CMD_CURS_ON,       0x31    ; switch on cursor
                         000000BB    53         .equ SCN2674_CMD_WC2P,          0xbb    ; write from cursor to pointer
                         000000AB    54         .equ SCN2674_CMD_WAC,           0xab    ; write at cursor
