                                     55         ;; --- 0x29 - RW: x pos low -------------------------------------------
                         00000029    56         .equ    EF9367_XPOS_LO,         0x29
                                     57         ;; --- 0x2a - RW: y pos hi --------------------------------------------
                         0000002A    58         .equ    EF9367_YPOS_HI,         0x2a
                                     59         ;; --- 0x2b - RW: y pos low -------------------------------------------
                         0000002B    60         .equ    EF9367_YPOS_LO,         0x2b
                                     61 
                                     62 
                                     63         ;; --- 0x2f - R:the status (NI) register and its bitmask --------------
                         0000002F    64         .equ    EF9367_STS_NI,          0x2f    ; status reg. (no interrupt reset)
                         00000002    65         .equ    EF9367_STS_NI_VBLANK,   0x02    ; high during vertical blanking.
                         00000004    66         .equ    EF9367_STS_NI_READY,    0x04    ; low when executing command
                                     67 
                                     68         ;; --- 0x30 - R/W:PIO gr. common register -----------------------------
                         00000030    69         .equ    PIO_GR_CMN,             0x30
ASxxxx Assembler V02.00 + NoICE + SDCC mods  (Zilog Z80 / Hitachi HD64180 / ZX-Next / eZ80 / R800)                          Page 4
Hexadecimal [32-Bits]



                                     16 
                                     17         .area    _CODE
                                     18 
                                     19         ;; ---------------------
                                     20         ;; rect_t *gnormrect(
                                     21         ;;     rect_t *r)
                                     22         ;; ---------------------
    00000000                         23 _gnormrect:
                                     24         ;; move HL to IY
    00000000 E5               [11]   25         push    hl
    00000001 FD E1            [14]   26         pop     iy
                                     27         ;; iy=pointer to rect...
    00000003                         28 gnormrectraw:
                                     29         ;; now compare x0 and x1
    00000003 FD 6E 00         [19]   30         ld      l,(iy)                  ; hl=x0
    00000006 FD 66 01         [19]   31         ld      h,1(iy)         
    00000009 FD 5E 04         [19]   32         ld      e,4(iy)                 ; de=x1
    0000000C FD 56 05         [19]   33         ld      d,5(iy)
    0000000F AF               [ 4]   34         xor     a                       ; clear carry
    00000010 ED 52            [15]   35         sbc     hl,de                   ; test
    00000012 38 0E            [12]   36         jr      c,gnr_test_y            ; second is larger, we're done
                                     37         ;; if we are here, switch values
    00000014 19               [11]   38         add     hl,de                   ; restore hl
    00000015 EB               [ 4]   39         ex      de,hl                   ; switch
    00000016 FD 75 00         [19]   40         ld      (iy),l                  ; hl=x0
    00000019 FD 74 01         [19]   41         ld      1(iy),h         
    0000001C FD 73 04         [19]   42         ld      4(iy),e                 ; de=x1
    0000001F FD 72 05         [19]   43         ld      5(iy),d
                                     44         ;; now test y...
    00000022                         45 gnr_test_y:
    00000022 FD 6E 02         [19]   46         ld      l,2(iy)                 ; hl=y0
    00000025 FD 66 03         [19]   47         ld      h,3(iy)         
    00000028 FD 5E 06         [19]   48         ld      e,6(iy)                 ; de=y1
    0000002B FD 56 07         [19]   49         ld      d,7(iy)
    0000002E AF               [ 4]   50         xor     a                       ; clear carry
    0000002F ED 52            [15]   51         sbc     hl,de                   ; test (again!)
    00000031 38 0E            [12]   52         jr      c,gnr_done              ; all good!
                                     53         ;; switch values
    00000033 19               [11]   54         add     hl,de                   ; restore hl
    00000034 EB               [ 4]   55         ex      de,hl                   ; switch
    00000035 FD 75 02         [19]   56         ld      2(iy),l                 ; hl=x0
    00000038 FD 74 03         [19]   57         ld      3(iy),h         
    0000003B FD 73 06         [19]   58         ld      6(iy),e                 ; de=x1
    0000003E FD 72 07         [19]   59         ld      7(iy),d
                                     60         ;; and done!
    00000041                         61 gnr_done:
    00000041 FD E5            [15]   62         push    iy                      ; return rect ptr.
    00000043 E1               [10]   63         pop     hl
    00000044 C9               [10]   64         ret        
